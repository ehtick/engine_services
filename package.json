{
  "name": "thatopen-services",
  "private": false,
  "version": "0.6.1",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "bin": {
    "thatopen": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.config.cli.mts",
    "build:lib": "tsc && vite build",
    "build:cli": "vite build --config vite.config.cli.mts",
    "preview": "vite preview",
    "test:ui": "vite --config test/vite.config.mts",
    "test:cli-build": "npm run build:cli && node test/setup-test-app.mjs",
    "test:cli-serve": "cd temp/test-app && thatopen dev --platform",
    "create-version": "yarn build && yarn changeset && yarn changeset version && yarn changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@types/node": "^20.12.12",
    "commander": "^14.0.3",
    "eslint": "9.x",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^15.3.0",
    "jszip": "^3.10.1",
    "prettier": "^3.2.5",
    "tsx": "^4.16.2",
    "typescript": "^5.2.2",
    "typescript-eslint": "^7.10.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "socket.io-client": "^4.8.0"
  }
}
